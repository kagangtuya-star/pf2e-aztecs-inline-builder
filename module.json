{
   "id": "pf2e-aztecs-inline-builder",
   "title": "PF2e Aztec's Inline Builder",
   "description": "A dynamic interface for generating and inserting inline PF2e rolls, checks, and damage.",
   "version": "#{VERSION}#",
   "compatibility": {
      "minimum": "13",
      "verified": "14"
   },
   "authors": [
      {
         "name": "Aztec"
      }
   ],
   "esmodules": ["src/main.js"],
   "styles": ["styles/styles.css"],
   "languages": [
      {
         "lang": "en",
         "name": "English",
         "path": "languages/en.json"
      },
      {
         "lang": "ru",
         "name": "Русский",
         "path": "languages/ru.json"
      },
      {
         "lang": "uk",
         "name": "Українська",
         "path": "languages/ua.json"
      },
      {
         "lang": "cn",
         "name": "简体中文",
         "path": "languages/zh_Hans.json"
      }
   ],
   "url": "#{URL}#",
   "manifest": "#{MANIFEST}#",
   "download": "#{DOWNLOAD}#"
}
